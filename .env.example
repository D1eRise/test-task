APP_URL=http://localhost:8080
APP_TIMEZONE=Europe/Moscow
APP_TARGET_STAGE=DELIVERY
APP_TARGET_CATEGORY=main
APP_WEBHOOK_SECRET=__SET_WEBHOOK_SECRET__
APP_MAX_WEBHOOK_BYTES=65536
APP_DRY_RUN=0
BP_ENABLED=0

BITRIX_MEMBER_ID=__SET_BITRIX_MEMBER_ID__
BITRIX_WEBHOOK_URL=https://__SET_YOUR_BITRIX_HOST__/rest/__SET_USER_ID__/__SET_WEBHOOK_CODE__
BITRIX_APP_REST_URL=
BITRIX_APP_ACCESS_TOKEN=
BITRIX_REQUESTS_PER_SECOND=2
BITRIX_TIMEOUT_MS=3000
BITRIX_MAX_RETRIES=5
BITRIX_DEAL_ENTITY_TYPE_ID=2
BITRIX_FIELD_CITY_CODE_TO=UF_CRM_CITY_CODE_TO
BITRIX_FIELD_WEIGHT_KG=UF_CRM_WEIGHT_KG
BITRIX_FIELD_SLA_DUE_AT=UF_CRM_SLA_DUE_AT
BITRIX_FIELD_RISK_SCORE=UF_CRM_RISK_SCORE
BITRIX_FIELD_ETA_DAYS=UF_CRM_ETA_DAYS
BITRIX_FIELD_DELIVERY_ZONE=UF_CRM_DELIVERY_ZONE
BITRIX_FIELD_DIAGNOSTIC_HASH=UF_CRM_DIAGNOSTIC_HASH
BITRIX_FIELD_RAW_QUOTE_JSON=UF_CRM_RAW_QUOTE_JSON
BITRIX_TASK_CREATOR_ID=0
BITRIX_BP_TEMPLATE_ID=0

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=__SET_RABBITMQ_USER__
RABBITMQ_PASS=__SET_RABBITMQ_PASS__
RABBITMQ_VHOST=/
RABBITMQ_QUEUE=delivery.events

DB_PATH=/app/var/app.sqlite

COURIER_QUOTE_URL=http://courier-mock:8080/v1/quote
COURIER_TIMEOUT_MS=2000

SIMULATE_DEAL_IDS=
